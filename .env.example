# ========== CONFIGURAÇÃO DE DESENVOLVIMENTO ==========

# Ambiente
ENVIRONMENT=development

# Autenticação Básica (usuario:senha,usuario2:senha2)
BASIC_AUTH_USERS=admin:admin123,dev:dev123,test:test123

# Redis/Upstash (configure com seus valores reais)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Pipefy (se aplicável - configure com sua sessão real)
PHPSESSID=your_session_id_here

# CORS Origins para desenvolvimento
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# Chave secreta para JWT (mude em produção)
SECRET_KEY=development-secret-key-change-in-production

# Logging
LOG_LEVEL=DEBUG

# Rate Limiting (mais permissivo em desenvolvimento)
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# Configurações de Cache
CACHE_DEFAULT_TTL=1800
CACHE_COURSES_TTL=3600
CACHE_USERS_TTL=7200

# Configurações de Compressão
ENABLE_COMPRESSION=true
MIN_COMPRESSION_SIZE=1024

# Configurações de Segurança (relaxadas para desenvolvimento)
ENABLE_SECURITY_HEADERS=true
REQUIRE_HTTPS=false
BLOCK_SUSPICIOUS_IPS=false

# Configurações de Monitoramento
ENABLE_METRICS=true
SLOW_REQUEST_THRESHOLD=2.0
MEMORY_ALERT_THRESHOLD=0.95
